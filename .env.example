# ==============================================================================
# INSTRUCCIONES PARA CONFIGURAR EL ENTORNO LOCAL:
# 1. Haz una copia de este archivo y renómbralo a exactamente ".env"
#    (Asegúrate de que quede en la raíz del proyecto, al lado de pom.xml).
# 2. Reemplaza los valores de prueba que están abajo con las credenciales
#    reales de tu base de datos local (PostgreSQL).
#
# NOTA: El archivo .env está ignorado en Git (.gitignore), por lo que
# tus contraseñas locales nunca se subirán al repositorio.
# ==============================================================================

DB_USERNAME=usuario_db
DB_PASSWORD=password_db